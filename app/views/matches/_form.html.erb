<%= form_with(model: @match) do |form| %>
  <div class="space-y-6">
    <div>
      <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :title, class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>

    <div class="grid grid-cols-2 gap-6">
      <div>
        <%= form.label :date, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.date_field :date, class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500" %>
      </div>
      <div>
        <%= form.label :team, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :team, class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500" %>
      </div>
    </div>

    <div>
      <%= form.label :opponent, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_field :opponent, class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div>
      <%= form.label :notes, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.text_area :notes, rows: 4, class: "w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-500" %>
    </div>

    <div class="pt-6">
      <%= form.submit @match.new_record? ? "Create Match" : "Update Match", 
                      class: "w-full bg-blue-600 hover:bg-blue-700 text-white py-3.5 rounded-xl font-medium text-lg transition" %>
    </div>
  </div>
<% end %>