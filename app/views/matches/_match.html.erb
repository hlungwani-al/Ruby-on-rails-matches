<div id="<%= dom_id match %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= match.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Date:</strong>
    <%= match.date %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Opponent:</strong>
    <%= match.opponent %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Team:</strong>
    <%= match.team %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Notes:</strong>
    <%= match.notes %>
  </div>
</div>
